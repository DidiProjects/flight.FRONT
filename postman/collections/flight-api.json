              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "DELETE /airlines/:code",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/airlines/:code",
              "host": ["{{baseUrl}}"],
