            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET /users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "20" },
                { "key": "status", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "GET /users?status=pending",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=20&status=pending",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "20" },
                { "key": "status", "value": "pending" }
              ]
            }
          }
        },
        {
          "name": "GET /users/:id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "PATCH /users/:id/approve",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/users/:id/approve",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id", "approve"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"user\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "PATCH /users/:id",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"user\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "DELETE /users/:id",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        }
      ]
    },
    {
